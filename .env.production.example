# Production deployment profile.
# Copy to your deployment secret store or CI/CD environment variables.

RAG_AUTH_MODE=gateway
RAG_ALLOW_HEADER_AUTH_IN_DEV=false
RAG_AUTH_HEADER_DEBUG_ENABLED=false
RAG_GATEWAY_SHARED_SECRET=replace-with-a-long-random-secret
RAG_GATEWAY_SECRET_HEADER=X-Auth-Gateway-Secret
RAG_GATEWAY_USER_ID_HEADER=X-Auth-User-Id
RAG_GATEWAY_ROLES_HEADER=X-Auth-Roles
RAG_GATEWAY_CHANNEL_HEADER=X-Auth-Channel
RAG_GATEWAY_TENANT_ID_HEADER=X-Auth-Tenant-Id
RAG_GATEWAY_ORG_ID_HEADER=X-Auth-Org-Id

RAG_VECTOR_BACKEND=chroma
RAG_CHROMA_HTTP_URL=http://chroma:8000
RAG_LLM_PROVIDER=none
RAG_DATA_DIR=/data
RAG_RAW_UPLOAD_DIR=/data/raw
RAG_PROCESSED_DIR=/data/processed
RAG_VECTORDB_DIR=/data/vectordb
RAG_CHROMA_DIR=/data/vectordb/chroma
RAG_CACHE_DIR=/data/cache
RAG_SQLITE_PATH=/data/metadata.db
RAG_LOG_LEVEL=INFO
RAG_BACKGROUND_WORKER_ENABLED=false
RAG_BACKGROUND_WORKER_POLL_INTERVAL_SECONDS=0.5
RAG_BACKGROUND_WORKER_HEARTBEAT_INTERVAL_SECONDS=5
RAG_BACKGROUND_WORKER_STALE_SECONDS=60
RAG_SCHEDULED_SYNC_ENABLED=true
RAG_SCHEDULED_SYNC_POLL_INTERVAL_SECONDS=10

# Notification Center + outbound webhook delivery for operations alerts.
RAG_NOTIFICATION_WEBHOOK_ENABLED=false
RAG_NOTIFICATION_WEBHOOK_URL=
RAG_NOTIFICATION_WEBHOOK_SECRET=
RAG_NOTIFICATION_WEBHOOK_TIMEOUT_SECONDS=10
RAG_NOTIFICATION_WEBHOOK_MAX_ATTEMPTS=3

# MCP server exposes internal tool registry at POST /mcp.
# Keep disabled until the gateway protects this endpoint.
RAG_MCP_SERVER_ENABLED=false
RAG_MCP_PROTOCOL_VERSION=2025-06-18
RAG_MCP_SERVER_NAME=AgentBusiness MCP
RAG_MCP_SERVER_VERSION=0.1.0
RAG_MCP_REQUIRE_AUTH=true
RAG_MCP_VALIDATE_ORIGIN=true
# Set to the trusted MCP web/client origins before enabling.
RAG_MCP_ALLOWED_ORIGINS=
RAG_MCP_REQUIRE_TOOL_SCOPES=true
# Keep empty unless a high/critical tool has a documented external-use approval.
RAG_MCP_HIGH_RISK_TOOL_ALLOWLIST=
# Use a long random secret from the gateway/secret manager.
RAG_MCP_MANIFEST_SIGNING_SECRET=
# V2 client token gate. Use sha256 tokens from the gateway/secret manager.
RAG_MCP_REQUIRE_CLIENT_TOKEN=true
RAG_MCP_CLIENT_TOKEN_HEADER=X-MCP-Client-Token
RAG_MCP_CLIENT_TOKENS=
# V2 per-client/tool quota. Example: partner-app:search_kb:60,*:list_customer_tickets:30.
RAG_MCP_DEFAULT_TOOL_QUOTA_PER_WINDOW=60
RAG_MCP_TOOL_QUOTA_WINDOW_SECONDS=60
RAG_MCP_TOOL_QUOTAS=
RAG_MCP_EXPOSED_TOOLS=search_kb,list_kbs,get_kb_stats,list_google_drive_sources,get_google_drive_sync_status,list_support_emails,read_email_thread,list_customer_tickets,add_ticket_internal_note

# In-app rate limiting. Keep a gateway/WAF limiter in front for multi-instance production.
RAG_RATE_LIMIT_ENABLED=true
RAG_RATE_LIMIT_WINDOW_SECONDS=60
RAG_RATE_LIMIT_DEFAULT_REQUESTS_PER_WINDOW=600
RAG_RATE_LIMIT_CHAT_REQUESTS_PER_WINDOW=60
RAG_RATE_LIMIT_MCP_REQUESTS_PER_WINDOW=120
RAG_RATE_LIMIT_UPLOAD_REQUESTS_PER_WINDOW=20
RAG_RATE_LIMIT_ADMIN_REQUESTS_PER_WINDOW=300
RAG_RATE_LIMIT_SYNC_REQUESTS_PER_WINDOW=60
RAG_RATE_LIMIT_EXEMPT_PATHS=/health,/api/system

# OpenTelemetry tracing. Send traces to an OTEL Collector/Grafana/Datadog endpoint.
RAG_OTEL_ENABLED=false
RAG_OTEL_SERVICE_NAME=agent-business
RAG_OTEL_ENVIRONMENT=production
RAG_OTEL_EXPORTER=otlp
RAG_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
RAG_OTEL_EXPORTER_OTLP_HEADERS=
RAG_OTEL_TRACE_CONTENT=false
RAG_OTEL_FAIL_CLOSED=false

# Optional production integrations.
# RAG_GOOGLE_DRIVE_ENABLED=true
# RAG_GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=/run/secrets/google-drive-service-account.json
# RAG_EMAIL_INTEGRATION_ENABLED=true
