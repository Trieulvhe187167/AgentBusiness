# Local RAG Agent configuration
# Copy to .env and enable only the sections you need.

# ------------------------------------------------------------------
# MVP / easiest local mode
# No remote model server required.
# ------------------------------------------------------------------
RAG_VECTOR_BACKEND=numpy
RAG_LLM_PROVIDER=none
RAG_ANSWER_MODE=auto
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=10
RAG_MAX_UPLOAD_SIZE_MB=50
RAG_LOG_LEVEL=INFO

# Optional local paths
# RAG_DATA_DIR=data
# RAG_SQLITE_PATH=data/metadata.db
# RAG_EMBEDDING_MODEL_PATH=models/paraphrase-multilingual-MiniLM-L12-v2

# ------------------------------------------------------------------
# Vector store: advanced / larger datasets
# ------------------------------------------------------------------
# chroma | numpy
# RAG_VECTOR_BACKEND=chroma
RAG_CHROMA_COLLECTION_NAME=kb_chunks

# Set only when using an external Chroma server.
# RAG_CHROMA_HTTP_URL=http://localhost:8000

# ------------------------------------------------------------------
# Retrieval thresholds
# ------------------------------------------------------------------
RAG_MIN_SIMILARITY_THRESHOLD=0.30
RAG_THRESHOLD_GOOD=0.60
RAG_THRESHOLD_LOW=0.40

# Used only when sentence-transformers is unavailable.
RAG_HASHING_MIN_SIMILARITY_THRESHOLD=0.12
RAG_HASHING_THRESHOLD_GOOD=0.32
RAG_HASHING_THRESHOLD_LOW=0.18

# ------------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------------
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_BATCH_SIZE=64
# Optional manual prefixes for some embedding families:
# RAG_EMBEDDING_QUERY_PREFIX=
# RAG_EMBEDDING_PASSAGE_PREFIX=

# ------------------------------------------------------------------
# OpenAI-compatible / vLLM: advanced mode
# ------------------------------------------------------------------
# RAG_LLM_PROVIDER=openai_compatible
RAG_LLM_BASE_URL=http://127.0.0.1:8000/v1
RAG_LLM_API_KEY=EMPTY
RAG_LLM_MODEL=Qwen/Qwen3-4B-Instruct-2507

# Agent runtime contract for the advanced mode
RAG_AGENT_SERVING_STACK=vllm
RAG_AGENT_TOOL_PROTOCOL=manual_json
RAG_AGENT_NATIVE_TOOL_CALLING=false
RAG_AGENT_TOOL_CHOICE_MODE=auto
RAG_AGENT_BRAIN_MODE=hybrid
# RAG_AGENT_TOOL_PARSER=qwen3_coder

# ------------------------------------------------------------------
# OpenAI: optional advanced mode
# ------------------------------------------------------------------
# RAG_LLM_PROVIDER=openai
# RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------------------------------
# Gemini: optional advanced mode
# ------------------------------------------------------------------
# RAG_LLM_PROVIDER=gemini
# RAG_GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-2.0-flash
RAG_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ------------------------------------------------------------------
# Ollama: optional advanced mode
# ------------------------------------------------------------------
# RAG_LLM_PROVIDER=ollama
# RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=qwen2.5:3b

# ------------------------------------------------------------------
# llama.cpp: optional advanced mode
# ------------------------------------------------------------------
# RAG_LLM_PROVIDER=llama_cpp
# RAG_LLM_MODEL_PATH=models/your-model.gguf
RAG_LLM_N_CTX=2048
RAG_LLM_MAX_TOKENS=768
RAG_LLM_TEMPERATURE=0.25
RAG_LLM_TOP_P=0.9

# ------------------------------------------------------------------
# Session / logs
# ------------------------------------------------------------------
RAG_SESSION_TTL_MINUTES=120
RAG_CHAT_LOG_LIMIT_DEFAULT=50

# ------------------------------------------------------------------
# Authentication / authorization
# ------------------------------------------------------------------
# dev = allow local header-based auth for testing
# jwt = require Authorization: Bearer <token>
# gateway = trust only X-Auth-* headers signed by an internal gateway/backend secret
# For production deploys, prefer `.env.production.example` or docker-compose.prod.yml.
RAG_AUTH_MODE=dev
RAG_ALLOW_HEADER_AUTH_IN_DEV=true

# Used in JWT mode to validate issuer / audience.
# RAG_JWT_ISSUER=https://your-issuer.example.com/
# RAG_JWT_AUDIENCE=campusrag-api

# Production OIDC/JWKS verification endpoint for RS256 tokens.
# RAG_JWT_JWKS_URL=https://your-issuer.example.com/.well-known/jwks.json

# Optional local/shared-secret mode for HS256 tokens in dev or tests.
# RAG_JWT_SHARED_SECRET=change-me

# Trusted gateway mode for website-backend integration.
# The upstream website backend or reverse proxy injects these headers,
# and the browser must never know the shared secret.
# RAG_AUTH_MODE=gateway
# RAG_GATEWAY_SHARED_SECRET=change-me
# RAG_ALLOW_HEADER_AUTH_IN_DEV=false
# RAG_GATEWAY_SECRET_HEADER=X-Auth-Gateway-Secret
# RAG_GATEWAY_USER_ID_HEADER=X-Auth-User-Id
# RAG_GATEWAY_ROLES_HEADER=X-Auth-Roles
# RAG_GATEWAY_CHANNEL_HEADER=X-Auth-Channel
# RAG_GATEWAY_TENANT_ID_HEADER=X-Auth-Tenant-Id
# RAG_GATEWAY_ORG_ID_HEADER=X-Auth-Org-Id

# ------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------
RAG_CACHE_TTL_SECONDS=3600
RAG_CACHE_MAX_SIZE_MB=500

# ------------------------------------------------------------------
# Background worker
# ------------------------------------------------------------------
# Local/dev keeps an in-process worker in FastAPI. Production can set
# this false on the API container and run `python -m app.worker`.
RAG_BACKGROUND_WORKER_ENABLED=true
RAG_BACKGROUND_WORKER_POLL_INTERVAL_SECONDS=0.5
RAG_BACKGROUND_WORKER_HEARTBEAT_INTERVAL_SECONDS=5
RAG_BACKGROUND_WORKER_STALE_SECONDS=60
RAG_SCHEDULED_SYNC_ENABLED=true
RAG_SCHEDULED_SYNC_POLL_INTERVAL_SECONDS=10

# ------------------------------------------------------------------
# External business integrations: advanced mode only
# ------------------------------------------------------------------
RAG_INTEGRATION_CACHE_TTL_SECONDS=120
RAG_INTEGRATION_HTTP_TIMEOUT_SECONDS=15

# Order API
# RAG_ORDER_API_BASE_URL=http://127.0.0.1:9001
# RAG_ORDER_API_KEY=
RAG_ORDER_API_STATUS_PATH=/orders/status
RAG_ORDER_API_RECENT_PATH=/orders/recent

# Game API
# RAG_GAME_API_BASE_URL=http://127.0.0.1:9002
# RAG_GAME_API_KEY=
RAG_GAME_API_ONLINE_PATH=/alliances/online

# ------------------------------------------------------------------
# Google Drive -> KB sync: advanced admin mode only
# ------------------------------------------------------------------
# RAG_GOOGLE_DRIVE_ENABLED=true
# RAG_GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=secrets/google-drive-service-account.json
# Optional domain-wide delegation subject:
# RAG_GOOGLE_DRIVE_DELEGATED_SUBJECT=
RAG_GOOGLE_DRIVE_TIMEOUT_SECONDS=30
RAG_GOOGLE_DRIVE_EXPORT_GOOGLE_DOC_AS=docx
RAG_GOOGLE_DRIVE_EXPORT_GOOGLE_SHEET_AS=xlsx
RAG_GOOGLE_DRIVE_EXPORT_GOOGLE_SLIDE_AS=pdf
RAG_GOOGLE_DRIVE_SYNC_BATCH_SIZE=50

# ------------------------------------------------------------------
# Support Email action tools: Gmail/Outlook mailbox via IMAP + SMTP
# ------------------------------------------------------------------
# RAG_EMAIL_INTEGRATION_ENABLED=true
RAG_EMAIL_PROVIDER=imap_smtp
# Gmail IMAP/SMTP:
# RAG_EMAIL_IMAP_HOST=imap.gmail.com
# RAG_EMAIL_SMTP_HOST=smtp.gmail.com
# Outlook IMAP/SMTP:
# RAG_EMAIL_IMAP_HOST=outlook.office365.com
# RAG_EMAIL_SMTP_HOST=smtp.office365.com
RAG_EMAIL_IMAP_PORT=993
RAG_EMAIL_IMAP_MAILBOX=INBOX
RAG_EMAIL_IMAP_USE_SSL=true
# RAG_EMAIL_IMAP_USERNAME=support@example.com
# RAG_EMAIL_IMAP_PASSWORD=
RAG_EMAIL_SMTP_PORT=587
RAG_EMAIL_SMTP_USE_TLS=true
RAG_EMAIL_SMTP_USE_SSL=false
# RAG_EMAIL_SMTP_USERNAME=support@example.com
# RAG_EMAIL_SMTP_PASSWORD=
# RAG_EMAIL_FROM_ADDRESS=support@example.com
# RAG_EMAIL_SUPPORT_ADDRESS=support@example.com
RAG_EMAIL_LOOKBACK_DAYS=7
RAG_EMAIL_FETCH_LIMIT=20
