# Local RAG Agent - Product-like configuration
# Copy this file to .env and adjust values.

# -------------------------------
# Core paths / runtime
# -------------------------------
# RAG_DATA_DIR=data
# RAG_SQLITE_PATH=data/metadata.db

# -------------------------------
# Embeddings
# -------------------------------
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
# For multilingual retrieval:
# RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Higher-quality multilingual (heavier):
# RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Or:
# RAG_EMBEDDING_MODEL=BAAI/bge-m3

# Offline embedding model path (optional)
# RAG_EMBEDDING_MODEL_PATH=models/all-MiniLM-L6-v2

RAG_EMBEDDING_BATCH_SIZE=64
# Optional manual prefixes (auto-detected for e5/bge if left empty)
# RAG_EMBEDDING_QUERY_PREFIX=
# RAG_EMBEDDING_PASSAGE_PREFIX=

# -------------------------------
# Vector backend
# -------------------------------
# chroma (recommended) | numpy (fallback)
RAG_VECTOR_BACKEND=chroma
RAG_CHROMA_COLLECTION_NAME=kb_chunks

# Use this only when connecting to an external Chroma server
# RAG_CHROMA_HTTP_URL=http://localhost:8000

# -------------------------------
# Retrieval / mode thresholds
# -------------------------------
RAG_TOP_K=10
RAG_MIN_SIMILARITY_THRESHOLD=0.30
RAG_THRESHOLD_GOOD=0.60
RAG_THRESHOLD_LOW=0.40

# Auto thresholds used only when sentence-transformers is unavailable
RAG_HASHING_MIN_SIMILARITY_THRESHOLD=0.12
RAG_HASHING_THRESHOLD_GOOD=0.32
RAG_HASHING_THRESHOLD_LOW=0.18

# -------------------------------
# Answer mode
# -------------------------------
# auto | extractive | generative
RAG_ANSWER_MODE=auto

# auto | openai | gemini | ollama | llama_cpp | none
RAG_LLM_PROVIDER=auto

# -------------------------------
# OpenAI (product path)
# -------------------------------
# RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_OPENAI_BASE_URL=https://api.openai.com/v1

# -------------------------------
# Gemini (product path)
# -------------------------------
# RAG_GEMINI_API_KEY=
RAG_GEMINI_MODEL=gemini-2.0-flash
RAG_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# -------------------------------
# Ollama (local path)
# -------------------------------
# RAG_OLLAMA_BASE_URL=http://localhost:11434
RAG_OLLAMA_MODEL=qwen2.5:3b

# -------------------------------
# llama.cpp (local path)
# -------------------------------
# RAG_LLM_MODEL_PATH=models/qwen2.5-1.5b-instruct-q4_k_m.gguf
RAG_LLM_N_CTX=2048
RAG_LLM_MAX_TOKENS=768
RAG_LLM_TEMPERATURE=0.25
RAG_LLM_TOP_P=0.9

# -------------------------------
# Chunking
# -------------------------------
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=120

# -------------------------------
# Upload + cache
# -------------------------------
RAG_MAX_UPLOAD_SIZE_MB=50
RAG_CACHE_TTL_SECONDS=3600
RAG_CACHE_MAX_SIZE_MB=500

# -------------------------------
# Session / logs
# -------------------------------
RAG_SESSION_TTL_MINUTES=120
RAG_CHAT_LOG_LIMIT_DEFAULT=50

# -------------------------------
# Logging
# -------------------------------
RAG_LOG_LEVEL=INFO
